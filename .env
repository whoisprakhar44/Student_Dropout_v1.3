# ── Model ─────────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=qwen3.5:2b
OLLAMA_NUM_CTX=4096
OLLAMA_NUM_PREDICT=512
OLLAMA_REASONING=true
RAG_TOP_K=4
# OLLAMA_REASONING: set to true to enable chain-of-thought thinking (recommended for small models like 2b)
#                   set to false to disable (faster, lower memory, use for larger models ≥7b)

# ── MCP Server paths (override defaults in tools.py if needed) ────────────────
# RAG_SERVER_PATH=./servers/retrieval_mcp_server.py
# TOOL_SERVER_PATH=./servers/tool_mcp_server.py

# Hive MCP stub (disabled by default; not wired into the local graph)
HIVE_MCP_ENABLED=false
HIVE_HOST=
HIVE_PORT=10000
HIVE_DATABASE=curated_datamodels
HIVE_AUTH_MODE=NONE
HIVE_USERNAME=
HIVE_PASSWORD=
